[Unit]
Description=Cube Sandbox Web UI container
After=docker.service network-online.target cube-sandbox-cube-api.service
Requires=docker.service
Wants=network-online.target cube-sandbox-cube-api.service
ConditionPathExists=/usr/local/services/cubetoolbox/.one-click.env
PartOf=cube-sandbox-control.target

[Service]
Type=simple
User=root
WorkingDirectory=/usr/local/services/cubetoolbox
EnvironmentFile=-/usr/local/services/cubetoolbox/.one-click.env
ExecStart=/usr/local/services/cubetoolbox/scripts/systemd/webui-start.sh
ExecStartPost=/usr/local/services/cubetoolbox/scripts/systemd/webui-postcheck.sh
ExecStop=/usr/local/services/cubetoolbox/scripts/systemd/webui-stop.sh
Restart=on-failure
RestartSec=2s

[Install]
WantedBy=cube-sandbox-control.target
